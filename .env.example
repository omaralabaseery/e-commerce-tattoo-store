# Copy to .env on the server and fill in real values. Never commit .env.

# Postgres password (also used by the backend datasource)
POSTGRES_PASSWORD=change-me-strong-db-password

# JWT signing secret — MUST be a long random string (>= 32 chars).
# Generate one with: openssl rand -base64 48
APP_JWT_SECRET=change-me-generate-a-long-random-secret

# Comma-separated origins allowed to call the API (your storefront URL)
APP_CORS_ORIGINS=https://yourdomain.com

# Public URL of the backend API as seen from the browser
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
